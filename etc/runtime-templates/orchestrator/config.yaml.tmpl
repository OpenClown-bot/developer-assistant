model:
  default: {{model_main}}
  provider: custom
  api_key: {{omniroute_api_key}}
  base_url: {{omniroute_base_url}}
  fallback:
    model: {{fallback_1}}
    on_errors:
    - timeout
    - rate_limit
    - server_error

providers: {}
fallback_providers: []

gateway:
  enabled: {{gateway_enabled}}

skills:
  built_in:
{{built_in_skills}}
  external_dirs:
    - /srv/devassist/shared-skills/
  delegate_task:
    enabled: false
  skill_manage:
    enabled: false

plugins:
  dev-assist-escalation-policy:
    enabled: true
  dev-assist-work-queue:
    enabled: true

approvals:
  mode: manual

system_prompt:
  path: {{repo_path}}/{{prompt_file}}

memory:
  path: /srv/devassist/runtimes/{{role}}/.hermes/memories/

sessions:
  path: /srv/devassist/runtimes/{{role}}/.hermes/sessions/

operational_db:
  path: /srv/devassist/runtimes/{{role}}/.hermes/operational.db

cron:
  enabled: true

env:
  HERMES_DEVASSIST_ROLE: {{role}}
  HERMES_HOME: /srv/devassist/runtimes/{{role}}/.hermes/
{{terminal_block}}
