# TKT-034 § 6 — opt-in test fixture for verify-self.sh
# `check_required_env_vars_present`. Loaded by tests that explicitly
# point INSTALL_DRY_RUN_PREFIX at a tmpdir and copy this file into
# srv/devassist/secrets/SELF-DEPLOY.env.
#
# All values here are placeholder strings (test-token-placeholder,
# test-user-placeholder) per TKT-034 AC-12: no real credentials may
# ever appear in this file or anywhere else in the repo.
TELEGRAM_BOT_TOKEN=test-token-placeholder
TELEGRAM_ALLOWED_USERS=test-user-placeholder
DEVASSIST_FOUNDER_TELEGRAM_USER_ID=test-user-placeholder
GITHUB_TOKEN=test-token-placeholder
FIREWORKS_API_KEY=test-token-placeholder
OMNIROUTE_BASE_URL=http://127.0.0.1:20128/v1
OPENROUTER_API_KEY=
HERMES_DEVASSIST_REPO_URL=https://github.com/OpenClown-bot/developer-assistant.git
HERMES_DEVASSIST_REPO_BRANCH=main
OPERATOR_GIT_USER_NAME=test-operator
OPERATOR_GIT_USER_EMAIL=test-operator@example.com
